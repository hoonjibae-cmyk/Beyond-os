SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SECRET_KEY=YOUR_SUPABASE_SECRET_KEY
ADMIN_PASSWORD=원하는_관리자_비밀번호

# 선택사항: 위클리 리포트 AI 주간 총평 초안 및 학생 관리 이력 상담 요약 생성용
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
# 선택사항: 학생 관리 이력 상담 요약 전용 모델. 비워두면 GPT_SUMMARY_MODEL → OPENAI_MODEL → gpt-4o-mini 순으로 사용합니다.
GPT_SUMMARY_MODEL=

# 운영 주소 / 공개 리포트 링크
PUBLIC_APP_URL=https://실제배포주소
NEXT_PUBLIC_APP_URL=https://실제배포주소

# 리포트 발송 라우팅: Beyond OS 내부 Webhook Route로 연결
REPORT_SEND_WEBHOOK_URL=https://실제배포주소/api/kakao-send-webhook
WEEKLY_REPORT_SEND_WEBHOOK_URL=https://실제배포주소/api/kakao-send-webhook
# 선택: 내부 Webhook 보호용 시크릿
KAKAO_SEND_WEBHOOK_SECRET=

# 카카오/SOLAPI Provider Adapter 기본 안전 설정
KAKAO_PROVIDER_MODE=mock
KAKAO_FAIL_SAFE_MODE=true
KAKAO_RECIPIENT_TEST_MODE=true
KAKAO_TEST_RECIPIENT_PHONE=
KAKAO_RECIPIENT_ALLOWLIST=

# v40-94 SOLAPI 전용 Adapter
# 템플릿 승인 후 KAKAO_PROVIDER_MODE=solapi 로 전환하세요.
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_CHANNEL_ID=
SOLAPI_TEMPLATE_ID_DAILY=
SOLAPI_TEMPLATE_ID_WEEKLY=
SOLAPI_TEMPLATE_ID_ATTENDANCE=
SOLAPI_TEMPLATE_ID_PARENT_CONFIRMATION=
# 선택사항: 기본값은 SOLAPI 공식 발송 endpoint입니다.
SOLAPI_API_URL=https://api.solapi.com/messages/v4/send-many/detail
# 선택사항: 대체문자 발송을 막기 위해 기본 true입니다.
SOLAPI_DISABLE_SMS=true

# v40-115 키오스크 알림톡 출결 자동반영 Bridge
# 안드로이드 브릿지 앱/자동화 앱이 /api/kiosk-attendance-bridge 로 POST할 때 사용합니다.
KIOSK_BRIDGE_SECRET=충분히_긴_랜덤_문자열

# 선택사항: Direct Kakao Adapter를 직접 사용할 때 승인된 템플릿 코드
KAKAO_TEMPLATE_CODE_DAILY=
KAKAO_TEMPLATE_CODE_WEEKLY=
KAKAO_TEMPLATE_CODE_ATTENDANCE=

# v41-09 출결 알림 정책
# 출결 알림 ON/OFF와 복귀 지연 기준은 Beyond OS 화면의 system_settings.report_send_settings에 저장됩니다.
# SOLAPI_TEMPLATE_ID_ATTENDANCE는 입실/퇴실/외출/복귀/복귀 지연을 모두 커버하는 승인된 출결 알림톡 템플릿 ID를 넣는 것을 권장합니다.
# SOLAPI_TEMPLATE_ID_PARENT_CONFIRMATION에는 시간표 알림센터의 학부모 확인 요청용 승인 템플릿 ID를 넣습니다.
